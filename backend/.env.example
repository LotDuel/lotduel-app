# LotDuel Backend Environment Variables

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string-in-production

# Database (dev uses SQLite by default, prod needs PostgreSQL)
# DATABASE_URL=postgresql://lotduel:password@localhost:5432/lotduel

# Frontend URL (for CORS and invite link generation)
FRONTEND_URL=http://localhost:5173

# MarketCheck API (free tier: 500 calls/month)
MARKETCHECK_API_KEY=your-api-key-here

# Admin webhook token (for remote deploys — keep this secret)
ADMIN_TOKEN=generate-with-python3-c-import-secrets-secrets.token_urlsafe-32
